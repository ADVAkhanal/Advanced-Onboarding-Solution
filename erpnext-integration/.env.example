# Pinned ERPNext version (the tag of the ADVAkhanal/erpnext fork / frappe image).
ERPNEXT_VERSION=v15

# Site + credentials (change these).
SITE_NAME=erp.advancedpmc.localhost
DB_PASSWORD=change-me-strong
ADMIN_PASSWORD=change-me-strong

# These are consumed by the Shop-Management (Next.js) app, NOT by Docker.
# Set them in the Next.js environment after creating an API key/secret in ERPNext:
#   ERPNEXT_BASE_URL=https://erp.advancedpmc.com
#   ERPNEXT_API_KEY=...
#   ERPNEXT_API_SECRET=...
