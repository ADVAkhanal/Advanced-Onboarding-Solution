  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  ownerId        String?
  archivedAt     DateTime?

  @@index([organizationId, reportId])
  @@map("report_exports")
}

model ReportTemplate {
  id             String   @id @default(cuid())
  organizationId String
  reportType     String
  title          String
  description    String?
  defaultFormat  ExportFormat @default(PDF)
  templateData   Json?
  active         Boolean  @default(true)
  status         String   @default("Active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  ownerId        String?
  archivedAt     DateTime?

  @@unique([organizationId, reportType])
  @@map("report_templates")
}

model Notification {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  title          String
  body           String
  channel        String   @default("in_app")
  readAt         DateTime?
  status         String   @default("Unread")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  ownerId        String?
  archivedAt     DateTime?

  @@index([organizationId, userId, status])
  @@map("notifications")
}

model Setting {
  id             String   @id @default(cuid())
  organizationId String
  key            String
  value          Json?
  description    String?
  status         String   @default("Active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  ownerId        String?
  archivedAt     DateTime?

  @@unique([organizationId, key])
  @@map("settings")
}

model FileMetadata {
  id             String   @id @default(cuid())
  organizationId String
  originalName   String
  storageKey     String
  mimeType       String
  sizeBytes      Int
  checksum       String?
  uploadedById   String
  safeUse        String
  status         String   @default("Uploaded")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  ownerId        String?
  archivedAt     DateTime?

  @@index([organizationId, uploadedById])
  @@map("file_metadata")
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  actorId        String?
  action         String
  entityType     String
  entityId       String?
  departmentId   String?
  ownerId        String?
  outcome        String   @default("SUCCESS")
  reason         String?
  ipAddress      String?
  userAgent      String?
  before         Json?
  after          Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  archivedAt     DateTime?

  @@index([organizationId, entityType, entityId])
  @@index([organizationId, actorId, createdAt])
  @@map("audit_log")
}

model ImportJob {
  id             String   @id @default(cuid())
  organizationId String
  importType     String
  sourceName     String
  status         String   @default("Queued")
  startedAt      DateTime?
  completedAt    DateTime?
  summary        Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  ownerId        String?
  archivedAt     DateTime?

  @@index([organizationId, status])
  @@map("import_jobs")
}

model ImportRow {
  id             String   @id @default(cuid())
  organizationId String
  importJobId    String
  rowNumber      Int
  rawData        Json
  normalizedData Json?
  status         String   @default("Pending")
  errorMessage   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  ownerId        String?
  archivedAt     DateTime?

  @@index([organizationId, importJobId, status])
  @@map("import_rows")
}
