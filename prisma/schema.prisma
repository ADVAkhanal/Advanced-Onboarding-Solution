model PayrollRequestStatusHistory {
  id             String   @id @default(cuid())
  organizationId String
  payrollRequestId String
  fromStatus     String?
  toStatus       String
  changedById    String
  reason         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  ownerId        String?
  archivedAt     DateTime?

  @@index([organizationId, payrollRequestId])
  @@map("payroll_request_status_history")
}

model PayrollExport {
  id             String       @id @default(cuid())
  organizationId String
  payrollPeriodId String?
  exportNumber   String
  format         ExportFormat
  safeFieldSet   Json?
  generatedById  String
  generatedAt    DateTime     @default(now())
  status         String       @default("Generated")
  fileMetadataId String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  ownerId        String?
  archivedAt     DateTime?

  @@unique([organizationId, exportNumber])
