model PayrollRequestComment {
  id             String   @id @default(cuid())
  organizationId String
  payrollRequestId String
  body           String
  authorId       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  ownerId        String?
  archivedAt     DateTime?

  @@index([organizationId, payrollRequestId])
  @@map("payroll_request_comments")
