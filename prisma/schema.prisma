model TicketCenter {
  id             String    @id @default(cuid())
  organizationId String
  departmentId   String
  name           String
  slug           String
  managerId      String?
  directorId     String?
  routingRules   Json?
  metricsConfig  Json?
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdById    String?
  updatedById    String?
  ownerId        String?
  archivedAt     DateTime?

  @@unique([organizationId, slug])
  @@index([organizationId, departmentId])
  @@map("ticket_centers")
}

model TicketCategory {
  id             String    @id @default(cuid())
  organizationId String
  departmentId   String
  ticketCenterId String
  name           String
  slug           String
  description    String?
  defaultPriority RequestPriority @default(NORMAL)
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdById    String?
  updatedById    String?
  ownerId        String?
  archivedAt     DateTime?

  @@unique([organizationId, ticketCenterId, slug])
  @@index([organizationId, departmentId])
  @@map("ticket_categories")
}

model Ticket {
  id                           String          @id @default(cuid())
  organizationId               String
  ticketNumber                 String
  departmentId                 String
  ticketCenterId               String
  categoryId                   String?
  title                        String
  description                  String
  requestedById                String
  requestedForId               String?
  assignedManagerId            String?
  assignedOwnerId              String?
  priority                     RequestPriority @default(NORMAL)
  status                       String          @default("New")
  dueDate                      DateTime?
  targetDate                   DateTime?
  locationId                   String?
  shiftId                      String?
  relatedEmployeeId            String?
  relatedOnboardingCaseId      String?
  relatedPayrollRequestId      String?
  relatedEquipmentRequestId    String?
  relatedTrainingAssignmentId  String?
  reopenedCount                Int             @default(0)
  escalationStatus             String?
  resolutionNotes              String?
  closedById                   String?
  closedAt                     DateTime?
  createdAt                    DateTime        @default(now())
  updatedAt                    DateTime        @updatedAt
  createdById                  String?
  updatedById                  String?
  ownerId                      String?
  archivedAt                   DateTime?

  @@unique([organizationId, ticketNumber])
  @@index([organizationId, departmentId, status])
  @@index([organizationId, assignedOwnerId])
  @@index([organizationId, dueDate])
  @@map("tickets")
}

model TicketComment {
  id             String   @id @default(cuid())
  organizationId String
  ticketId       String
  body           String
  authorId       String
  visibility     VisibilityLevel @default(VISIBLE_TO_EMPLOYEE)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  ownerId        String?
  archivedAt     DateTime?

  @@index([organizationId, ticketId])
