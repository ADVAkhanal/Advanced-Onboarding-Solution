generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserLevel {
  USER
  MANAGER
  DIRECTOR
  ADMIN
}

enum EmploymentType {
  EMPLOYEE
  CONTRACTOR
  TEMP
  INTERN
  SEASONAL
}

enum VisibilityLevel {
  PRIVATE_TO_MANAGER
  VISIBLE_TO_DIRECTOR
  VISIBLE_TO_HR_ADMIN
  VISIBLE_TO_EMPLOYEE
  EXECUTIVE_RESTRICTED
}

enum RequestPriority {
  LOW
  NORMAL
  HIGH
  URGENT
  WORK_STOPPAGE
}

enum ExportFormat {
  PDF
  DOCX
  XLSX
  CSV
  MARKDOWN
  HTML
  JSON
}

model Organization {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  legalName   String?
  brandName   String?
  logoUrl     String?
  timezone    String    @default("America/Chicago")
  settings    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String?
  updatedById String?
  archivedAt  DateTime?

  @@map("organizations")
}

model User {
  id             String     @id @default(cuid())
  organizationId String
  email          String
  passwordHash   String
  firstName      String
  lastName       String
  title          String?
  phone          String?
  avatarUrl      String?
  userLevel      UserLevel
  status         String     @default("ACTIVE")
  departmentId   String?
  managerId      String?
  directorId     String?
  lastLoginAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  createdById    String?
  updatedById    String?
  archivedAt     DateTime?

  @@unique([organizationId, email])
  @@index([organizationId, userLevel])
  @@index([organizationId, departmentId])
  @@map("users")
}

model UserDepartmentAccess {
  id             String    @id @default(cuid())
  organizationId String
  userId         String
  departmentId   String
  accessLevel    String    @default("MEMBER")
  grantedById    String?
  status         String    @default("ACTIVE")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdById    String?
  updatedById    String?
  ownerId        String?
  archivedAt     DateTime?

  @@unique([organizationId, userId, departmentId])
  @@index([organizationId, departmentId])
  @@map("user_department_access")
}

model Session {
  id             String    @id @default(cuid())
  organizationId String
  userId         String
  tokenHash      String
  expiresAt      DateTime
  ipAddress      String?
  userAgent      String?
  status         String    @default("ACTIVE")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  ownerId        String?
  archivedAt     DateTime?

  @@unique([organizationId, tokenHash])
  @@index([organizationId, userId, expiresAt])
  @@map("sessions")
}

model PayrollCoordinationRequest {
  id                String          @id @default(cuid())
  organizationId    String
  requestNumber     String
  employeeName      String?
  employeeProfileId String?
  departmentId      String
  managerId         String?
  requestType       String
  effectiveDate     DateTime?
  payPeriod         String?
  safeSummary       String
  businessReason    String?
  status            String          @default("SUBMITTED")
  exportStatus      String          @default("NOT_EXPORTED")
  priority          RequestPriority @default(NORMAL)
  comments          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  createdById       String?
  updatedById       String?
  ownerId           String?
  archivedAt        DateTime?

  @@unique([organizationId, requestNumber])
  @@index([organizationId, departmentId, status])
  @@map("payroll_coordination_requests")
}

model AttendanceIssue {
  id                String    @id @default(cuid())
  organizationId    String
  recordNumber      String
  employeeName      String?
  employeeProfileId String?
  departmentId      String
  managerId         String?
  issueType         String
  issueDate         DateTime
  shiftId           String?
  description       String
  payrollImpact     Boolean   @default(false)
  notes             String?
  status            String    @default("SUBMITTED")
  priority          RequestPriority @default(NORMAL)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  createdById       String?
  updatedById       String?
  ownerId           String?
  archivedAt        DateTime?

  @@unique([organizationId, recordNumber])
  @@index([organizationId, departmentId, status])
  @@map("attendance_issues")
}

model Task {
  id             String          @id @default(cuid())
  organizationId String
  title          String
  description    String?
  departmentId   String?
  assignedToId   String?
  priority       RequestPriority @default(NORMAL)
  dueDate        DateTime?
  status         String          @default("NOT_STARTED")
  linkedTicketId String?
  linkedOnboardingCaseId String?
  linkedPayrollRequestId String?
  linkedTimeOffRequestId String?
  comments       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  createdById    String?
  updatedById    String?
  ownerId        String?
  archivedAt     DateTime?

  @@index([organizationId, departmentId, status])
  @@index([organizationId, assignedToId, status])
  @@map("tasks")
}

model NotificationLog {
  id             String    @id @default(cuid())
  organizationId String
  channel        String
  eventType      String
  recipient      String?
  title          String
  body           String
  status         String    @default("QUEUED")
  response       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  ownerId        String?
  archivedAt     DateTime?

  @@index([organizationId, eventType, status])
  @@map("notification_logs")
}

model AppSetting {
  id             String    @id @default(cuid())
  organizationId String
  key            String
  value          Json?
  description    String?
  status         String    @default("ACTIVE")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  ownerId        String?
  archivedAt     DateTime?

  @@unique([organizationId, key])
  @@map("app_settings")
}

model Role {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  description    String?
  userLevel      UserLevel
  systemKey      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdById    String?
  updatedById    String?
  archivedAt     DateTime?

  @@unique([organizationId, systemKey])
  @@map("roles")
}

model Permission {
  id             String   @id @default(cuid())
  organizationId String
  key            String
  label          String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  archivedAt     DateTime?

  @@unique([organizationId, key])
  @@map("permissions")
}

model UserRole {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  roleId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  archivedAt     DateTime?

  @@unique([organizationId, userId, roleId])
  @@index([organizationId, userId])
  @@map("user_roles")
}

model RolePermission {
  id             String   @id @default(cuid())
  organizationId String
  roleId         String
  permissionId   String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  archivedAt     DateTime?

  @@unique([organizationId, roleId, permissionId])
  @@map("role_permissions")
}

model Department {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  code           String
  description    String?
  directorId     String?
  managerId      String?
  locationId     String?
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdById    String?
  updatedById    String?
  ownerId        String?
  archivedAt     DateTime?

  @@unique([organizationId, code])
  @@index([organizationId, managerId])
  @@map("departments")
}

model Location {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  code           String
  address        String?
  city           String?
  state          String?
  postalCode     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdById    String?
  updatedById    String?
  archivedAt     DateTime?

  @@unique([organizationId, code])
  @@map("locations")
}

model Shift {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  code           String
  startTime      String?
  endTime        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdById    String?
  updatedById    String?
  archivedAt     DateTime?

  @@unique([organizationId, code])
  @@map("shifts")
}

model Team {
  id             String    @id @default(cuid())
  organizationId String
  departmentId   String
  name           String
  managerId      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdById    String?
  updatedById    String?
  ownerId        String?
  archivedAt     DateTime?

  @@index([organizationId, departmentId])
  @@map("teams")
}

model JobTitle {
  id             String    @id @default(cuid())
  organizationId String
  departmentId   String?
  title          String
  code           String?
  description    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdById    String?
  updatedById    String?
  archivedAt     DateTime?

  @@index([organizationId, departmentId])
  @@map("job_titles")
}

model TicketCenter {
  id             String    @id @default(cuid())
  organizationId String
  departmentId   String
  name           String
  slug           String
  managerId      String?
  directorId     String?
  routingRules   Json?
  metricsConfig  Json?
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdById    String?
  updatedById    String?
  ownerId        String?
  archivedAt     DateTime?

  @@unique([organizationId, slug])
  @@index([organizationId, departmentId])
  @@map("ticket_centers")
}

model TicketCategory {
  id             String    @id @default(cuid())
  organizationId String
  departmentId   String
  ticketCenterId String
  name           String
  slug           String
  description    String?
  defaultPriority RequestPriority @default(NORMAL)
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdById    String?
  updatedById    String?
  ownerId        String?
  archivedAt     DateTime?

  @@unique([organizationId, ticketCenterId, slug])
  @@index([organizationId, departmentId])
  @@map("ticket_categories")
}

model Ticket {
  id                           String          @id @default(cuid())
  organizationId               String
  ticketNumber                 String
  departmentId                 String
  ticketCenterId               String
  categoryId                   String?
  title                        String
  description                  String
  requestedById                String
  requestedForId               String?
  assignedManagerId            String?
  assignedOwnerId              String?
  priority                     RequestPriority @default(NORMAL)
  status                       String          @default("New")
  dueDate                      DateTime?
  targetDate                   DateTime?
  locationId                   String?
  shiftId                      String?
  relatedEmployeeId            String?
  relatedOnboardingCaseId      String?
  relatedPayrollRequestId      String?
  relatedEquipmentRequestId    String?
  relatedTrainingAssignmentId  String?
  reopenedCount                Int             @default(0)
  escalationStatus             String?
  resolutionNotes              String?
  closedById                   String?
  closedAt                     DateTime?
  createdAt                    DateTime        @default(now())
  updatedAt                    DateTime        @updatedAt
  createdById                  String?
  updatedById                  String?
  ownerId                      String?
  archivedAt                   DateTime?

  @@unique([organizationId, ticketNumber])
  @@index([organizationId, departmentId, status])
  @@index([organizationId, assignedOwnerId])
  @@index([organizationId, dueDate])
  @@map("tickets")
}

model TicketComment {
  id             String   @id @default(cuid())
  organizationId String
  ticketId       String
  body           String
  authorId       String
  visibility     VisibilityLevel @default(VISIBLE_TO_EMPLOYEE)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  ownerId        String?
  archivedAt     DateTime?

  @@index([organizationId, ticketId])
  @@map("ticket_comments")
}

model TicketInternalNote {
  id             String   @id @default(cuid())
  organizationId String
  ticketId       String
  body           String
  authorId       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  ownerId        String?
  archivedAt     DateTime?

  @@index([organizationId, ticketId])
  @@map("ticket_internal_notes")
}

model TicketAttachment {
  id             String   @id @default(cuid())
  organizationId String
  ticketId       String
  fileMetadataId String
  uploadedById   String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  ownerId        String?
  archivedAt     DateTime?

  @@index([organizationId, ticketId])
  @@map("ticket_attachments")
}

model TicketStatusHistory {
  id             String   @id @default(cuid())
  organizationId String
  ticketId       String
  fromStatus     String?
  toStatus       String
  changedById    String
  reason         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  ownerId        String?
  archivedAt     DateTime?

  @@index([organizationId, ticketId])
  @@map("ticket_status_history")
}

model TicketEscalation {
  id             String   @id @default(cuid())
  organizationId String
  ticketId       String
  escalatedById  String
  escalatedToId  String?
  reason         String
  status         String   @default("Escalated")
  resolvedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  ownerId        String?
  archivedAt     DateTime?

  @@index([organizationId, ticketId])
  @@map("ticket_escalations")
}

model OnboardingCase {
  id                         String    @id @default(cuid())
  organizationId             String
  caseNumber                 String
  firstName                  String
  lastName                   String
  preferredName              String?
  personalEmail              String?
  phone                      String?
  employeeId                 String?
  onboardingType             String
  employmentType             EmploymentType
  departmentId               String
  jobTitleId                 String?
  jobTitle                   String?
  managerId                  String?
  directorId                 String?
  startDate                  DateTime
  shiftId                    String?
  locationId                 String?
  workArea                   String?
  payType                    String?
  payRateSummary             String?
  payrollSetupRequired       Boolean   @default(false)
  timekeepingSetupRequired   Boolean   @default(false)
  equipmentRequired          Boolean   @default(false)
  softwareRequired           Boolean   @default(false)
  workspaceRequired          Boolean   @default(false)
  badgeKeyRequired           Boolean   @default(false)
  trainingRequired           Boolean   @default(false)
  policyAcknowledgmentsRequired Boolean @default(false)
  uniformPpeRequired         Boolean   @default(false)
  mentorBuddyId              String?
  firstDaySchedule           String?
  lunchMeetingPlan           String?
  readinessScore             Int       @default(0)
  status                     String    @default("Draft")
  notes                      String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  createdById                String?
  updatedById                String?
  ownerId                    String?
  archivedAt                 DateTime?

  @@unique([organizationId, caseNumber])
  @@index([organizationId, departmentId, status])
  @@index([organizationId, startDate])
  @@map("onboarding_cases")
}

model OnboardingTemplate {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  onboardingType String
  departmentId   String?
  jobTitleId      String?
  active         Boolean  @default(true)
  templateData   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  ownerId        String?
  archivedAt     DateTime?

  @@index([organizationId, departmentId])
  @@map("onboarding_templates")
}

model OnboardingChecklist {
  id             String   @id @default(cuid())
  organizationId String
  templateId     String?
  onboardingCaseId String?
  departmentId   String?
  name           String
  status         String   @default("Active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  ownerId        String?
  archivedAt     DateTime?

  @@index([organizationId, onboardingCaseId])
  @@map("onboarding_checklists")
}

model OnboardingChecklistItem {
  id             String   @id @default(cuid())
  organizationId String
  checklistId    String
  title          String
  description    String?
  departmentId   String?
  ownerRole      String?
  dueOffsetDays  Int?
  required       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  ownerId        String?
  status         String   @default("Active")
  archivedAt     DateTime?

  @@index([organizationId, checklistId])
  @@map("onboarding_checklist_items")
}

model OnboardingCaseItem {
  id             String   @id @default(cuid())
  organizationId String
  onboardingCaseId String
  title          String
  description    String?
  departmentId   String?
  ownerId        String?
  status         String   @default("Not Started")
  dueDate        DateTime?
  completedAt    DateTime?
  completionNotes String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  archivedAt     DateTime?

  @@index([organizationId, onboardingCaseId, status])
  @@map("onboarding_case_items")
}

model OnboardingMilestone {
  id             String   @id @default(cuid())
  organizationId String
  onboardingCaseId String
  milestoneType  String
  dueDate        DateTime?
  completedAt    DateTime?
  ownerId        String?
  status         String   @default("Pending")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  archivedAt     DateTime?

  @@index([organizationId, onboardingCaseId])
  @@map("onboarding_milestones")
}

model OnboardingComment {
  id             String   @id @default(cuid())
  organizationId String
  onboardingCaseId String
  body           String
  authorId       String
  visibility     VisibilityLevel @default(VISIBLE_TO_DIRECTOR)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  ownerId        String?
  archivedAt     DateTime?

  @@index([organizationId, onboardingCaseId])
  @@map("onboarding_comments")
}

model OnboardingDocument {
  id             String   @id @default(cuid())
  organizationId String
  onboardingCaseId String
  fileMetadataId String
  documentType   String
  acknowledgedAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  ownerId        String?
  status         String   @default("Uploaded")
  archivedAt     DateTime?

  @@index([organizationId, onboardingCaseId])
  @@map("onboarding_documents")
}

model OnboardingStatusHistory {
  id             String   @id @default(cuid())
  organizationId String
  onboardingCaseId String
  fromStatus     String?
  toStatus       String
  changedById    String
  reason         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  ownerId        String?
  archivedAt     DateTime?

  @@index([organizationId, onboardingCaseId])
  @@map("onboarding_status_history")
}

model PayrollPeriod {
  id             String   @id @default(cuid())
  organizationId String
  label          String
  startDate      DateTime
  endDate        DateTime
  dueDate        DateTime
  status         String   @default("Open")
  readinessScore Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  ownerId        String?
  archivedAt     DateTime?

  @@index([organizationId, startDate, endDate])
  @@map("payroll_periods")
}

model PayrollChangeRequest {
  id                         String   @id @default(cuid())
  organizationId             String
  requestNumber              String
  employeeProfileId          String?
  departmentId               String
  managerId                  String?
  requestType                String
  effectiveDate              DateTime?
  payrollPeriodId            String?
  currentValueSummary        String?
  proposedChangeSummary      String
  businessReason             String
  managerRecommendation      String?
  directorApprovalRequired   Boolean  @default(false)
  payrollAdminReviewRequired Boolean  @default(true)
  status                     String   @default("Draft")
  exportStatus               String   @default("Not Exported")
  notes                      String?
  createdAt                  DateTime @default(now())
