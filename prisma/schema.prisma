generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserLevel {
  USER
  MANAGER
  DIRECTOR
  ADMIN
}

enum EmploymentType {
  EMPLOYEE
  CONTRACTOR
  TEMP
  INTERN
  SEASONAL
}

enum VisibilityLevel {
  PRIVATE_TO_MANAGER
  VISIBLE_TO_DIRECTOR
  VISIBLE_TO_HR_ADMIN
  VISIBLE_TO_EMPLOYEE
  EXECUTIVE_RESTRICTED
}

enum RequestPriority {
  LOW
  NORMAL
  HIGH
  URGENT
  WORK_STOPPAGE
}

enum ExportFormat {
  PDF
  DOCX
  XLSX
  CSV
  MARKDOWN
  HTML
  JSON
}

// Manufacturing-aware quoting enums.
// Broad categories only — these never carry CUI alloy specs or
// export-controlled technical data. The fields exist so cycle-time
// lookups can be indexed; specific alloys / drawings remain off-platform.

enum MaterialCategory {
  ALLOY_STEEL
  STAINLESS_STEEL
  CARBON_STEEL
  ALUMINUM
  TITANIUM
  BRASS
  COPPER
  NICKEL_ALLOY
  PLASTIC
  COMPOSITE
  OTHER
}

enum ManufacturingProcess {
  TURNING
  MILLING
  MULTI_SPINDLE
  SWISS_TURNING
  GRINDING
  EDM
  WIRE_EDM
  HONING
  LAPPING
  INSPECTION
  ASSEMBLY
  OTHER
}

enum ComplexityClass {
  SIMPLE
  MODERATE
  COMPLEX
  HIGHLY_COMPLEX
}

enum DiameterClass {
  UNDER_25_MM
  FROM_25_TO_75_MM
  FROM_75_TO_150_MM
  FROM_150_TO_300_MM
  OVER_300_MM
  NOT_APPLICABLE
}

model Organization {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  legalName   String?
  brandName   String?
  logoUrl     String?
  timezone    String    @default("America/Chicago")
  settings    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String?
  updatedById String?
  archivedAt  DateTime?

  @@map("organizations")
}

model User {
  id             String     @id @default(cuid())
  organizationId String
  email          String
  passwordHash   String
  firstName      String
  lastName       String
  title          String?
  phone          String?
  avatarUrl      String?
  userLevel      UserLevel
  status         String     @default("ACTIVE")
  departmentId   String?
  managerId      String?
  directorId     String?
  lastLoginAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  createdById    String?
  updatedById    String?
  archivedAt     DateTime?

  @@unique([organizationId, email])
  @@index([organizationId, userLevel])
  @@index([organizationId, departmentId])
  @@map("users")
}

model UserDepartmentAccess {
  id             String    @id @default(cuid())
  organizationId String
  userId         String
  departmentId   String
  accessLevel    String    @default("MEMBER")
  grantedById    String?
  status         String    @default("ACTIVE")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdById    String?
  updatedById    String?
  ownerId        String?
  archivedAt     DateTime?

  @@unique([organizationId, userId, departmentId])
  @@index([organizationId, departmentId])
  @@map("user_department_access")
}

model Session {
  id             String    @id @default(cuid())
  organizationId String
  userId         String
  tokenHash      String
  expiresAt      DateTime
  ipAddress      String?
  userAgent      String?
  status         String    @default("ACTIVE")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  ownerId        String?
  archivedAt     DateTime?

  @@unique([organizationId, tokenHash])
  @@index([organizationId, userId, expiresAt])
  @@map("sessions")
}

model PayrollCoordinationRequest {
  id                String          @id @default(cuid())
  organizationId    String
  requestNumber     String
  employeeName      String?
  employeeProfileId String?
  departmentId      String
  managerId         String?
  requestType       String
  effectiveDate     DateTime?
  payPeriod         String?
  safeSummary       String
  businessReason    String?
  status            String          @default("SUBMITTED")
  exportStatus      String          @default("NOT_EXPORTED")
  priority          RequestPriority @default(NORMAL)
  comments          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  createdById       String?
  updatedById       String?
  ownerId           String?
  archivedAt        DateTime?

  @@unique([organizationId, requestNumber])
  @@index([organizationId, departmentId, status])
  @@map("payroll_coordination_requests")
}

model AttendanceIssue {
  id                String    @id @default(cuid())
  organizationId    String
  recordNumber      String
  employeeName      String?
  employeeProfileId String?
  departmentId      String
  managerId         String?
  issueType         String
  issueDate         DateTime
  shiftId           String?
  description       String
  payrollImpact     Boolean   @default(false)
  notes             String?
  status            String    @default("SUBMITTED")
  priority          RequestPriority @default(NORMAL)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  createdById       String?
  updatedById       String?
  ownerId           String?
  archivedAt        DateTime?

  @@unique([organizationId, recordNumber])
  @@index([organizationId, departmentId, status])
  @@map("attendance_issues")
}

model Task {
  id             String          @id @default(cuid())
  organizationId String
  title          String
  description    String?
  departmentId   String?
  assignedToId   String?
  priority       RequestPriority @default(NORMAL)
  dueDate        DateTime?
  status         String          @default("NOT_STARTED")
  linkedTicketId String?
  linkedOnboardingCaseId String?
  linkedPayrollRequestId String?
  linkedTimeOffRequestId String?
  comments       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  createdById    String?
  updatedById    String?
  ownerId        String?
  archivedAt     DateTime?

  @@index([organizationId, departmentId, status])
  @@index([organizationId, assignedToId, status])
  @@map("tasks")
}

model NotificationLog {
  id             String    @id @default(cuid())
  organizationId String
  channel        String
  eventType      String
  recipient      String?
  title          String
  body           String
  status         String    @default("QUEUED")
  response       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  ownerId        String?
  archivedAt     DateTime?

  @@index([organizationId, eventType, status])
  @@map("notification_logs")
}

model AppSetting {
  id             String    @id @default(cuid())
  organizationId String
  key            String
  value          Json?
  description    String?
  status         String    @default("ACTIVE")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  ownerId        String?
  archivedAt     DateTime?

  @@unique([organizationId, key])
  @@map("app_settings")
}

model Role {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  description    String?
  userLevel      UserLevel
  systemKey      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdById    String?
  updatedById    String?
  archivedAt     DateTime?

  @@unique([organizationId, systemKey])
  @@map("roles")
}

model Permission {
  id             String   @id @default(cuid())
  organizationId String
  key            String
  label          String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  archivedAt     DateTime?

  @@unique([organizationId, key])
  @@map("permissions")
}

model UserRole {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  roleId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  archivedAt     DateTime?

  @@unique([organizationId, userId, roleId])
  @@index([organizationId, userId])
  @@map("user_roles")
}

model RolePermission {
  id             String   @id @default(cuid())
  organizationId String
  roleId         String
  permissionId   String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  archivedAt     DateTime?

  @@unique([organizationId, roleId, permissionId])
  @@map("role_permissions")
}

model Department {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  code           String
  description    String?
  directorId     String?
  managerId      String?
  locationId     String?
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdById    String?
  updatedById    String?
  ownerId        String?
  archivedAt     DateTime?

  @@unique([organizationId, code])
  @@index([organizationId, managerId])
  @@map("departments")
}

model Location {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  code           String
  address        String?
  city           String?
  state          String?
  postalCode     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdById    String?
  updatedById    String?
  archivedAt     DateTime?

  @@unique([organizationId, code])
  @@map("locations")
}

model Shift {
  id             String    @id @default(cuid())
  organizationId String
  name           String
