model PayrollPeriodChecklist {
  id             String   @id @default(cuid())
  organizationId String
  payrollPeriodId String
  name           String
  status         String   @default("Open")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  ownerId        String?
  archivedAt     DateTime?

  @@index([organizationId, payrollPeriodId])
  @@map("payroll_period_checklists")
}

model PayrollPeriodChecklistItem {
  id             String   @id @default(cuid())
  organizationId String
  payrollPeriodChecklistId String
  title          String
  completed      Boolean  @default(false)
  completedById  String?
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?
  departmentId   String?
  ownerId        String?
  status         String   @default("Pending")
  archivedAt     DateTime?

  @@index([organizationId, payrollPeriodChecklistId])
  @@map("payroll_period_checklist_items")
}

model TimeOffRequest {
  id                  String   @id @default(cuid())
  organizationId      String
  requestNumber       String
  employeeProfileId   String
  departmentId        String
  managerId           String?
  timeOffType         String
  startDate           DateTime
  endDate             DateTime
  hoursRequested      Decimal?
  daysRequested       Decimal?
  reason              String?
  coveragePlan        String?
  managerDecision     String?
  directorDecision    String?
  status              String   @default("Draft")
  payrollNoteRequired Boolean  @default(false)
  exportedToPayroll   Boolean  @default(false)
  comments            String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdById         String?
  updatedById         String?
  ownerId             String?
  archivedAt          DateTime?

  @@unique([organizationId, requestNumber])
