DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cleanops_command_center?schema=public"
SESSION_SECRET="replace-with-a-strong-random-secret-at-least-32-characters"
BOOTSTRAP_ADMIN_EMAIL="admin@example.com"
BOOTSTRAP_ADMIN_PASSWORD="replace-with-a-temporary-strong-password"
APP_NAME="CleanOps Command Center"
COMPANY_NAME="Your Company"

# Optional
PUBLIC_BASE_URL="http://localhost:3000"
PUSHOVER_APP_TOKEN=""
PUSHOVER_USER_KEYS=""

# AI layer (SOP Knowledge Base assistant)
# Leave ANTHROPIC_API_KEY blank to disable AI features (the SOP ask endpoint
# returns a PROVIDER_ERROR and the admin UI shows a banner).
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# ProShop integration (read-only). Leave blank to disable — the ProShop
# Backlog dashboard then shows "Not connected" and never hits the network.
# Provide a root plus EITHER a bearer token OR client credentials.
PROSHOP_ROOT=""
PROSHOP_API_TOKEN=""
# PROSHOP_CLIENT_ID=""
# PROSHOP_CLIENT_SECRET=""
# PROSHOP_SCOPE=""

# Scheduled jobs. Set a strong random secret and configure a Railway cron
# (or external scheduler) to POST /api/cron/proshop-sync with header
# "x-cron-secret: <this value>". Leave blank to disable scheduled sync.
CRON_SECRET=""
